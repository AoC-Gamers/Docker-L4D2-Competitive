# =============================================================================
# DOCKER L4D2 COMPETITIVE CONTAINER CONFIGURATION
# =============================================================================
# IMPORTANT: This file contains sensitive credentials.
# - Copy this file to .env: cp example.env .env
# - Set restrictive permissions: chmod 600 .env
# - NEVER upload the .env file to Git (must be in .gitignore)

# -----------------------------------------------------------------------------
# AUTHENTICATION AND ACCESS
# -----------------------------------------------------------------------------

# Custom SSH port to access the container
# Recommended: Use a different port than 22 for security (e.g.: 2222)
SSH_PORT=

# Project name used by Docker Compose
# Controls the stack prefix for resources managed by Compose
# Default: docker-l4d2-competitive
PROJECT_NAME=docker-l4d2-competitive

# Container name used by Docker Compose
# Default: l4d2
CONTAINER_NAME=l4d2

# Image tag used by the published image
# Default: latest
IMAGE_TAG=latest

# Docker volume name used to persist runtime data
# Default: l4d2_data
DATA_VOLUME_NAME=l4d2_data

# `docker-compose.yml` y `docker-compose.dev.yml` consumen esta misma base.
# La diferencia entre ambos queda en usar una imagen publicada o un build local.

# Host directory mounted read-only into REPO_RESOURCES_DIR inside the container.
# Default: ./resources
HOST_REPO_RESOURCES_DIR=./resources

# Generic directory inside the container for repository-local artifacts.
# Default: /data/resources
REPO_RESOURCES_DIR=/data/resources

# -----------------------------------------------------------------------------
# L4D2 SERVER INSTALLATION CONTROL
# -----------------------------------------------------------------------------

# Controls base server installation behavior
# normal = install only if the server is missing
# skip   = do not install automatically
# force  = always run the installation/repair path
L4D2_INSTALL=normal

# Controls automatic server startup after deployment
# true  = start automatically
# false = do not start automatically
L4D2_AUTOSTART=true

# Controls whether the competitive stack is updated before starting the game servers
# true  = run install_stack.sh update during container startup, before the server start phase
# false = do not run a pre-start stack update automatically
L4D2_STACK_AUTOUPDATE=false

# Controls the legacy L4D2Updater bootstrap in the base image
# true  = enable updater bootstrap
# false = disable updater bootstrap
L4D2_UPDATER=true

# -----------------------------------------------------------------------------
# GeoIP Updates (optional)
# -----------------------------------------------------------------------------
# Enables the GeoIP bootstrap that refreshes MaxMind databases in SourceMod.
GEOIPUPDATE_ENABLED=false

# MaxMind account ID used for reference/config generation.
GEOIPUPDATE_ACCOUNT_ID=

# MaxMind license key used to download GeoLite archives during runtime updates.
GEOIPUPDATE_LICENSE_KEY=

# GeoIP edition to download.
GEOIPUPDATE_EDITION_ID=GeoLite2-City

# -----------------------------------------------------------------------------
# Stack Profile
# -----------------------------------------------------------------------------
# Stack profile used to materialize the runtime stack.
# Available values in this repo:
# - default : base competitive stack
STACK_PROFILE=default
