# =============================================================================
# DOCKER L4D2 COMPETITIVE CONTAINER CONFIGURATION
# =============================================================================
# IMPORTANT: This file contains sensitive credentials.
# - Copy this file to .env: cp example.env .env
# - Set restrictive permissions: chmod 600 .env
# - NEVER upload the .env file to Git (must be in .gitignore)

# -----------------------------------------------------------------------------
# AUTHENTICATION AND ACCESS
# -----------------------------------------------------------------------------

# Custom SSH port to access the container
# Recommended: Use a different port than 22 for security (e.g.: 2222)
SSH_PORT=

# Docker Compose project name for the runtime stack
# Controls the stack prefix for resources managed by Compose
# Default: docker-l4d2-competitive
COMPOSE_PROJECT_NAME=docker-l4d2-competitive

# Docker Compose project name for the development stack
# Default: docker-l4d2-competitive-dev
DEV_COMPOSE_PROJECT_NAME=docker-l4d2-competitive-dev

# Container name used by Docker Compose for the runtime service
# Default: comp_l4d2
COMP_CONTAINER_NAME=comp_l4d2

# Image tag used for the runtime image
# Default: latest
COMP_IMAGE_TAG=latest

# Docker volume name used to persist runtime data
# Default: comp_data
COMP_DATA_VOLUME_NAME=comp_data

# Container name used by Docker Compose for the development service
# Default: dev_comp
DEV_COMP_CONTAINER_NAME=dev_comp

# Docker volume name used to persist development data
# Default: dev_comp_data
DEV_COMP_DATA_VOLUME_NAME=dev_comp_data

# -----------------------------------------------------------------------------
# L4D2 SERVER INSTALLATION CONTROL
# -----------------------------------------------------------------------------

# Controls the server installation method
# false or empty = Automatic installation (Steam official if credentials available, otherwise workaround)
# true = Manual installation (skip automatic installation)
L4D2_NO_INSTALL=

# Controls automatic server startup after installation
# false or empty = Automatic server startup
# true = Do not start automatically (useful for manual configuration)
L4D2_NO_AUTOSTART=

# Controls L4D2Updater system installation (automatic updates)
# false or empty = Install L4D2Updater (recommended)
# true = Do not install automatic update system
L4D2_NO_UPDATER=

# -----------------------------------------------------------------------------
# Stack Profile
# -----------------------------------------------------------------------------
# Stack profile used to materialize the runtime stack.
# Common values in this repo:
# - latest  : production/runtime image
# - develop : development compose profile
STACK_PROFILE=